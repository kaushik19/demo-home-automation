# Toggle between mock data and a real backend.
# When VITE_USE_MOCK=true, all data comes from in-memory mock services (great for demos).
# When VITE_USE_MOCK=false, requests go to VITE_API_BASE_URL using the HTTP adapter.
VITE_USE_MOCK=true

# Real backend endpoints — only used when VITE_USE_MOCK=false
VITE_API_BASE_URL=https://api.example.com/v1
VITE_WS_URL=wss://api.example.com/v1/realtime

# Optional auth token to send as Bearer
VITE_API_TOKEN=
