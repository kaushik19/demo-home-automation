# --- Dependencies ---
node_modules/

# --- Build output ---
dist/
dist-ssr/
build/
.vite/
.cache/
.turbo/

# --- Local env (never commit) ---
.env
.env.*
!.env.example
*.local

# --- Editor / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.code-workspace

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Coverage / test artefacts ---
coverage/
.nyc_output/

# --- Tooling caches ---
.eslintcache
.stylelintcache

# --- Deploy artefacts (kept out of source control) ---
.vercel/
.netlify/
.cloudflare/
.wrangler/

# --- Misc ---
*.tsbuildinfo
*.pem
*.key
*.crt
